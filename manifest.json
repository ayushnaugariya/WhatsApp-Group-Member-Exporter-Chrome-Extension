{
  "manifest_version": 3,
  "name": "ContactVault",
  "version": "1.2.0",
  "description": "ContactVault — Export WhatsApp group member names and phone numbers to CSV, Excel & VCF contacts",
  "permissions": ["scripting"],
  "host_permissions": ["https://web.whatsapp.com/*"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
